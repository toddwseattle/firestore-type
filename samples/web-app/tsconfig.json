{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["vite/client"],
    "baseUrl": ".",
    "rootDirs": ["./src", "../../src", "../shared/src"],
    "paths": {
      "@bridgenodelabs/firestore-models": ["../../src/index.ts"],
      "@bridgenodelabs/firestore-models/core": ["../../src/core/index.ts"],
      "@bridgenodelabs/firestore-models/time": ["../../src/time/index.ts"],
      "@bridgenodelabs/firestore-models/adapters/firebase-client": [
        "../../src/adapters/firebase-client/index.ts"
      ],
      "@bridgenodelabs/firestore-models/adapters/firebase-admin": [
        "../../src/adapters/firebase-admin/index.ts"
      ],
      "@bridgenodelabs/firestore-models/react": [
        "../../src/react/index.ts"
      ]
    }
  },
  "include": ["src", "scripts", "vite.config.ts"]
}
