{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "./dist",
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "rootDirs": ["./src", "../../src"],
    "paths": {
      "@bridgenodelabs/firestore-models": ["../../src/index.ts"],
      "@bridgenodelabs/firestore-models/core": ["../../src/core/index.ts"],
      "@bridgenodelabs/firestore-models/time": ["../../src/time/index.ts"],
      "@bridgenodelabs/firestore-models/adapters/firebase-client": [
        "../../src/adapters/firebase-client/index.ts"
      ],
      "@bridgenodelabs/firestore-models/adapters/firebase-admin": [
        "../../src/adapters/firebase-admin/index.ts"
      ]
    }
  },
  "include": ["src/**/*.ts"]
}
