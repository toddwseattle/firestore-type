# Copy this file to .env.local and replace demo values as needed.

VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-project
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Optional extras
VITE_FIREBASE_STORAGE_BUCKET=demo-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_MEASUREMENT_ID=G-ABCDEFG123

# Emulator settings (defaults shown)
VITE_USE_FIREBASE_EMULATOR=true
VITE_FIREBASE_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_EMULATOR_PORT=8080

# Optional override for the sample project ID
PROJECT_TASKS_PROJECT_ID=project-demo
